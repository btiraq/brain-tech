<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="brainGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00C2D1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#007A85;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background circle -->
  <circle cx="256" cy="256" r="240" fill="url(#brainGradient)" stroke="#00C2D1" stroke-width="32"/>

  <!-- Brain icon -->
  <g transform="translate(256, 256)">
    <!-- Main brain shape -->
    <path d="M-80,-40 Q-60,-80 0,-80 Q60,-80 80,-40 Q100,0 80,40 Q60,80 0,80 Q-60,80 -80,40 Q-100,0 -80,-40 Z"
          fill="#050508" stroke="#00C2D1" stroke-width="4"/>

    <!-- Left hemisphere -->
    <circle cx="-40" cy="-20" r="15" fill="#00C2D1" opacity="0.8"/>
    <circle cx="-50" cy="10" r="12" fill="#00C2D1" opacity="0.6"/>
    <circle cx="-30" cy="30" r="10" fill="#00C2D1" opacity="0.7"/>

    <!-- Right hemisphere -->
    <circle cx="40" cy="-20" r="15" fill="#00C2D1" opacity="0.8"/>
    <circle cx="50" cy="10" r="12" fill="#00C2D1" opacity="0.6"/>
    <circle cx="30" cy="30" r="10" fill="#00C2D1" opacity="0.7"/>

    <!-- Neural connections -->
    <line x1="-40" y1="-20" x2="40" y2="-20" stroke="#00C2D1" stroke-width="3" opacity="0.6"/>
    <line x1="-50" y1="10" x2="-30" y2="30" stroke="#00C2D1" stroke-width="2" opacity="0.5"/>
    <line x1="50" y1="10" x2="30" y2="30" stroke="#00C2D1" stroke-width="2" opacity="0.5"/>
    <line x1="-40" y1="-20" x2="-50" y2="10" stroke="#00C2D1" stroke-width="2" opacity="0.4"/>
    <line x1="40" y1="-20" x2="50" y2="10" stroke="#00C2D1" stroke-width="2" opacity="0.4"/>
  </g>

  <!-- TECH text -->
  <text x="256" y="380" text-anchor="middle" fill="#E8EDF5" font-family="Arial, sans-serif" font-size="48" font-weight="bold">TECH</text>
</svg>